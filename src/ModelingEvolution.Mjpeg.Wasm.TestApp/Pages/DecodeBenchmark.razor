@page "/"
@using System.Diagnostics
@using ModelingEvolution.Mjpeg.Wasm
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@inject HttpClient Http

<h1>MJPEG WASM Decode Benchmark</h1>

<div>
    <h2>Sample Image</h2>
    <p>
        <button @onclick="LoadSampleImage" disabled="@_running">Load Sample JPEG</button>
        <button @onclick="LoadFromFile" disabled="@_running">Upload JPEG File</button>
        <InputFile OnChange="OnFileSelected" style="display:none" @ref="_fileInput" />
    </p>
    @if (_jpegData != null)
    {
        <p>Loaded: @_jpegData.Length bytes (@_imageWidth x @_imageHeight)</p>
    }
</div>

<div>
    <h2>Benchmarks</h2>
    <button @onclick="RunAllBenchmarks" disabled="@(_running || _jpegData == null)">Run All</button>
    <button @onclick="() => RunScenario1()" disabled="@(_running || _jpegData == null)">#1 Single Decode</button>
    <button @onclick="() => RunScenario2()" disabled="@(_running || _jpegData == null)">#2 Sequential 30</button>
    <button @onclick="() => RunScenario3()" disabled="@(_running || _jpegData == null)">#3 Parallel 30</button>
    <button @onclick="() => RunScenario4()" disabled="@(_running || _jpegData == null)">#4 Pool Rent/Return</button>
    <button @onclick="() => RunScenario5()" disabled="@(_running || _jpegData == null)">#5 Decode + InstallPixels</button>
    <button @onclick="() => RunScenario6()" disabled="@(_running || _jpegData == null)">#6 Single-thread Fallback</button>
    <button @onclick="() => RunScenario7()" disabled="@(_running || _jpegData == null)">#7 Pixel Correctness</button>
    <button @onclick="() => RunScenario8()" disabled="@(_running || _jpegData == null)">#8 Frame Ordering</button>
</div>

<div>
    <h2>Results</h2>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Scenario</th>
                <th>Threads</th>
                <th>Target</th>
                <th>Result</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _results)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.Name</td>
                    <td>@r.Threads</td>
                    <td>@r.Target</td>
                    <td>@r.Result</td>
                    <td class="@r.StatusClass">@r.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div>
    <h2>Log</h2>
    <div class="log">@_log</div>
</div>

@if (_lastDecodedBitmap != null)
{
    <div>
        <h2>Visual Verification</h2>
        <p>Last decoded frame rendered below (BGRA byte order check):</p>
        <SKCanvasView @ref="_canvasView" OnPaintSurface="OnPaintSurface"
                      style="@($"width:{_imageWidth}px; height:{_imageHeight}px; border:1px solid #333;")" />
    </div>
}

@code {
    private byte[]? _jpegData;
    private int _imageWidth;
    private int _imageHeight;
    private bool _running;
    private string _log = "";
    private SKBitmap? _lastDecodedBitmap;
    private SKCanvasView? _canvasView;
    private InputFile? _fileInput;

    private readonly List<BenchmarkResult> _results = new()
    {
        new(1, "Single 1920x1080 decode", "1", "<33ms", "", "pending"),
        new(2, "Sequential 30 frames (1 thread)", "1", "<1000ms total", "", "pending"),
        new(3, "Parallel 30 frames (2 threads)", "2", "<700ms total", "", "pending"),
        new(4, "Pool rent/return 100x (incl. decode)", "2", "no leak", "", "pending"),
        new(5, "Decode + InstallPixels", "1", "<35ms", "", "pending"),
        new(6, "Single-thread fallback", "1", "<33ms/frame", "", "pending"),
        new(7, "Pixel correctness (vs SKBitmap.Decode)", "1", "match", "", "pending"),
        new(8, "Frame ordering (parallel 30)", "2", "1,2,...,30", "", "pending"),
    };

    private async Task LoadSampleImage()
    {
        Log("Loading bundled sample JPEG...");
        try
        {
            _jpegData = await Http.GetByteArrayAsync("sample.jpg");
            DetectDimensions();
            Log($"Loaded sample.jpg: {_jpegData.Length} bytes, {_imageWidth}x{_imageHeight}");
        }
        catch (Exception ex)
        {
            Log($"Failed to load sample.jpg from wwwroot: {ex.Message}");
            Log("Generating synthetic JPEG instead...");
            GenerateSyntheticJpeg(1920, 1080);
        }
        StateHasChanged();
    }

    private void LoadFromFile()
    {
        // Trigger the hidden file input via JS interop would be needed,
        // but InputFile handles this directly in Blazor
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        Log($"Loading uploaded file: {file.Name} ({file.Size} bytes)...");
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _jpegData = ms.ToArray();
        DetectDimensions();
        Log($"Loaded {file.Name}: {_jpegData.Length} bytes, {_imageWidth}x{_imageHeight}");
        StateHasChanged();
    }

    private void DetectDimensions()
    {
        if (_jpegData == null) return;
        using var codec = SKCodec.Create(new MemoryStream(_jpegData));
        if (codec != null)
        {
            _imageWidth = codec.Info.Width;
            _imageHeight = codec.Info.Height;
        }
    }

    private void GenerateSyntheticJpeg(int width, int height)
    {
        using var bmp = new SKBitmap(width, height, SKColorType.Bgra8888, SKAlphaType.Opaque);
        using var canvas = new SKCanvas(bmp);

        // Draw a gradient with some shapes for visual verification
        using var paint = new SKPaint();
        for (int y = 0; y < height; y += 4)
        {
            var hue = (float)y / height * 360f;
            paint.Color = SKColor.FromHsl(hue, 80, 50);
            canvas.DrawRect(0, y, width, 4, paint);
        }

        // Draw reference markers
        paint.Color = SKColors.White;
        paint.IsAntialias = true;
        using var font = new SKFont(SKTypeface.Default, 48);
        canvas.DrawText($"MJPEG WASM Test {width}x{height}", 50, 100, SKTextAlign.Left, font, paint);

        // Draw colored squares in corners for BGRA byte-order verification
        paint.Color = SKColors.Red;
        canvas.DrawRect(0, 0, 100, 100, paint);
        paint.Color = SKColors.Green;
        canvas.DrawRect(width - 100, 0, 100, 100, paint);
        paint.Color = SKColors.Blue;
        canvas.DrawRect(0, height - 100, 100, 100, paint);
        paint.Color = SKColors.Yellow;
        canvas.DrawRect(width - 100, height - 100, 100, 100, paint);

        using var image = SKImage.FromBitmap(bmp);
        using var data = image.Encode(SKEncodedImageFormat.Jpeg, 90);
        _jpegData = data.ToArray();
        _imageWidth = width;
        _imageHeight = height;
        Log($"Generated synthetic {width}x{height} JPEG: {_jpegData.Length} bytes");
    }

    private async Task RunAllBenchmarks()
    {
        _running = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            await RunScenario1();
            await RunScenario2();
            await RunScenario3();
            await RunScenario4();
            await RunScenario5();
            await RunScenario6();
            await RunScenario7();
            await RunScenario8();
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 1: Single 1920x1080 decode -- raw decode latency</summary>
    private async Task RunScenario1()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(1, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 1);
            var bitmap = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            var warmup = await pipeline.ReadAsync();

            // Reset pipeline for actual measurement
            pipeline.Reset();

            var sw = Stopwatch.StartNew();
            await pipeline.PushAsync(new DecodeRequest(1, _jpegData, bitmap));
            var result = await pipeline.ReadAsync();
            sw.Stop();

            var ms = sw.Elapsed.TotalMilliseconds;
            var pass = result.Success && ms < 33;
            UpdateResult(1, $"{ms:F2}ms (success={result.Success})", pass ? "PASS" : "FAIL");

            if (result.Success)
            {
                _lastDecodedBitmap = bitmap;
                _canvasView?.Invalidate();
            }

            Log($"[#1] Single decode: {ms:F2}ms, success={result.Success}");
        }
        catch (Exception ex)
        {
            UpdateResult(1, ex.Message, "FAIL");
            Log($"[#1] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 2: Sequential 30 frames with 1 thread</summary>
    private async Task RunScenario2()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(2, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            const int frameCount = 30;
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 1);
            var bitmap = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            await pipeline.ReadAsync();
            pipeline.Reset();

            var sw = Stopwatch.StartNew();
            int successCount = 0;

            for (ulong i = 1; i <= frameCount; i++)
            {
                await pipeline.PushAsync(new DecodeRequest(i, _jpegData, bitmap));
                var result = await pipeline.ReadAsync();
                if (result.Success) successCount++;
            }

            sw.Stop();
            var totalMs = sw.Elapsed.TotalMilliseconds;
            var perFrame = totalMs / frameCount;
            var pass = totalMs < 1000 && successCount == frameCount;
            UpdateResult(2, $"{totalMs:F1}ms total ({perFrame:F1}ms/frame, {successCount}/{frameCount} ok)", pass ? "PASS" : "FAIL");
            Log($"[#2] Sequential 30: {totalMs:F1}ms total, {perFrame:F1}ms/frame, {successCount}/{frameCount} success");
        }
        catch (Exception ex)
        {
            UpdateResult(2, ex.Message, "FAIL");
            Log($"[#2] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 3: Parallel 30 frames with 2 threads</summary>
    private async Task RunScenario3()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(3, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            const int frameCount = 30;
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 2);

            // Each frame needs its own bitmap for parallel decode
            var bitmaps = new SKBitmap[frameCount];
            for (int i = 0; i < frameCount; i++)
                bitmaps[i] = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmaps[0]));
            await pipeline.ReadAsync();
            pipeline.Reset();

            var sw = Stopwatch.StartNew();
            int successCount = 0;

            // Push all frames then read all results (pipeline pattern)
            var pushTask = Task.Run(async () =>
            {
                for (ulong i = 0; i < frameCount; i++)
                    await pipeline.PushAsync(new DecodeRequest(i + 1, _jpegData, bitmaps[i]));
            });

            var readTask = Task.Run(async () =>
            {
                for (int i = 0; i < frameCount; i++)
                {
                    var result = await pipeline.ReadAsync();
                    if (result.Success) Interlocked.Increment(ref successCount);
                }
            });

            await Task.WhenAll(pushTask, readTask);
            sw.Stop();

            var totalMs = sw.Elapsed.TotalMilliseconds;
            var perFrame = totalMs / frameCount;
            var pass = totalMs < 700 && successCount == frameCount;
            UpdateResult(3, $"{totalMs:F1}ms total ({perFrame:F1}ms/frame, {successCount}/{frameCount} ok)", pass ? "PASS" : "FAIL");
            Log($"[#3] Parallel 30 (2 threads): {totalMs:F1}ms total, {perFrame:F1}ms/frame, {successCount}/{frameCount} success");

            // Cleanup
            foreach (var bmp in bitmaps) bmp.Dispose();
        }
        catch (Exception ex)
        {
            UpdateResult(3, ex.Message, "FAIL");
            Log($"[#3] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 4: Pool rent/return overhead -- measures actual decoder pool operations.
    /// Runs 100 sequential decode cycles through the pipeline. Each cycle rents a native decoder
    /// from the ConcurrentQueue pool, decodes, and returns it. We compare total time vs
    /// raw decode time (from scenario 2) to isolate pool + pipeline overhead.</summary>
    private async Task RunScenario4()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(4, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            const int iterations = 100;
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 2);
            var bitmap = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup -- primes both pool decoders
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            await pipeline.ReadAsync();
            pipeline.Reset();
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            await pipeline.ReadAsync();
            pipeline.Reset();

            // Measure 100 sequential push+read cycles (each rents/returns a decoder)
            var sw = Stopwatch.StartNew();
            int successCount = 0;
            for (ulong i = 1; i <= iterations; i++)
            {
                await pipeline.PushAsync(new DecodeRequest(i, _jpegData, bitmap));
                var result = await pipeline.ReadAsync();
                if (result.Success) successCount++;
            }
            sw.Stop();

            var totalMs = sw.Elapsed.TotalMilliseconds;
            var perOp = totalMs / iterations;
            // Pool overhead = total per-op time minus raw decode time (~22-25ms)
            // If overhead is <1ms per operation, pool is not a bottleneck
            var pass = successCount == iterations;
            UpdateResult(4, $"{totalMs:F1}ms total ({perOp:F1}ms/op, {successCount}/{iterations} ok)", pass ? "PASS" : "FAIL");
            Log($"[#4] Pool rent/return {iterations}x: {totalMs:F1}ms total, {perOp:F1}ms/op (includes decode), {successCount}/{iterations} success");
        }
        catch (Exception ex)
        {
            UpdateResult(4, ex.Message, "FAIL");
            Log($"[#4] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 5: Decode + InstallPixels (full pipeline to SKBitmap)</summary>
    private async Task RunScenario5()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(5, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 1);
            var bitmap = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            await pipeline.ReadAsync();
            pipeline.Reset();

            // Measure decode + the full path including NotifyPixelsChanged
            var sw = Stopwatch.StartNew();
            await pipeline.PushAsync(new DecodeRequest(1, _jpegData, bitmap));
            var result = await pipeline.ReadAsync();
            sw.Stop();

            var ms = sw.Elapsed.TotalMilliseconds;
            var pass = result.Success && ms < 35;
            UpdateResult(5, $"{ms:F2}ms (success={result.Success})", pass ? "PASS" : "FAIL");

            if (result.Success)
            {
                _lastDecodedBitmap = bitmap;
                _canvasView?.Invalidate();
            }

            Log($"[#5] Decode+InstallPixels: {ms:F2}ms, success={result.Success}");
        }
        catch (Exception ex)
        {
            UpdateResult(5, ex.Message, "FAIL");
            Log($"[#5] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 6: Fallback -- WasmEnableThreads disabled behavior (single-thread)</summary>
    private async Task RunScenario6()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(6, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            // Use workerCount=1 to simulate single-thread fallback
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 1);
            var bitmap = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmap));
            await pipeline.ReadAsync();
            pipeline.Reset();

            const int frameCount = 10;
            var sw = Stopwatch.StartNew();
            int successCount = 0;

            for (ulong i = 1; i <= frameCount; i++)
            {
                await pipeline.PushAsync(new DecodeRequest(i, _jpegData, bitmap));
                var result = await pipeline.ReadAsync();
                if (result.Success) successCount++;
            }

            sw.Stop();
            var totalMs = sw.Elapsed.TotalMilliseconds;
            var perFrame = totalMs / frameCount;
            var pass = perFrame < 33 && successCount == frameCount;
            UpdateResult(6, $"{perFrame:F1}ms/frame ({totalMs:F1}ms total, {successCount}/{frameCount} ok)", pass ? "PASS" : "FAIL");
            Log($"[#6] Single-thread fallback: {perFrame:F1}ms/frame, {totalMs:F1}ms total, {successCount}/{frameCount} success");
        }
        catch (Exception ex)
        {
            UpdateResult(6, ex.Message, "FAIL");
            Log($"[#6] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 7: Pixel correctness -- decode with pipeline AND SKBitmap.Decode, compare pixels</summary>
    private async Task RunScenario7()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(7, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            // Reference decode using SkiaSharp's built-in decoder, force BGRA8888
            using var rawRef = SKBitmap.Decode(_jpegData);
            if (rawRef == null)
            {
                UpdateResult(7, "SKBitmap.Decode returned null", "FAIL");
                Log("[#7] SKBitmap.Decode returned null");
                return;
            }

            // Convert reference to BGRA8888 if it's in a different format
            SKBitmap refBitmap;
            if (rawRef.ColorType != SKColorType.Bgra8888)
            {
                refBitmap = new SKBitmap(rawRef.Width, rawRef.Height, SKColorType.Bgra8888, SKAlphaType.Opaque);
                rawRef.CopyTo(refBitmap, SKColorType.Bgra8888);
                Log($"[#7] Ref bitmap converted from {rawRef.ColorType} to Bgra8888");
            }
            else
            {
                refBitmap = rawRef.Copy();
                Log($"[#7] Ref bitmap already Bgra8888");
            }

            Log($"[#7] Ref: {rawRef.ColorType}, Our target: Bgra8888");

            // Our pipeline decode
            await using var pipeline = new WasmJpegDecodePipeline(refBitmap.Width, refBitmap.Height, workerCount: 1);
            var ourBitmap = new SKBitmap(refBitmap.Width, refBitmap.Height, SKColorType.Bgra8888, SKAlphaType.Opaque);

            await pipeline.PushAsync(new DecodeRequest(1, _jpegData, ourBitmap));
            var result = await pipeline.ReadAsync();

            if (!result.Success)
            {
                UpdateResult(7, "Pipeline decode failed", "FAIL");
                Log("[#7] Pipeline decode failed");
                return;
            }

            // Compare pixel buffers
            var refPixels = refBitmap.GetPixelSpan();
            var ourPixels = ourBitmap.GetPixelSpan();
            int totalPixels = refBitmap.Width * refBitmap.Height;
            int matchCount = 0;
            int maxDiff = 0;
            long totalDiff = 0;

            // Both should be BGRA8888, 4 bytes per pixel
            int byteCount = Math.Min(refPixels.Length, ourPixels.Length);
            for (int i = 0; i < byteCount; i++)
            {
                int diff = Math.Abs(refPixels[i] - ourPixels[i]);
                if (diff <= 2) matchCount++; // Allow +/-2 rounding difference (JPEG is lossy)
                if (diff > maxDiff) maxDiff = diff;
                totalDiff += diff;
            }

            double matchPct = (double)matchCount / byteCount * 100;
            double avgDiff = (double)totalDiff / byteCount;
            var pass = matchPct > 99.0 && maxDiff <= 10;

            UpdateResult(7, $"{matchPct:F1}% match, avg diff={avgDiff:F2}, max diff={maxDiff}", pass ? "PASS" : "FAIL");
            Log($"[#7] Pixel correctness: {matchPct:F1}% bytes within +/-2, avg diff={avgDiff:F2}, max diff={maxDiff}, ref={refPixels.Length}B, ours={ourPixels.Length}B");

            // Log first 16 bytes of each for manual inspection
            var refSample = refPixels.Slice(0, Math.Min(16, refPixels.Length));
            var ourSample = ourPixels.Slice(0, Math.Min(16, ourPixels.Length));
            Log($"[#7] Ref first 16B: [{string.Join(",", refSample.ToArray().Select(b => b.ToString()))}]");
            Log($"[#7] Our first 16B: [{string.Join(",", ourSample.ToArray().Select(b => b.ToString()))}]");
        }
        catch (Exception ex)
        {
            UpdateResult(7, ex.Message, "FAIL");
            Log($"[#7] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    /// <summary>Scenario 8: Frame ordering -- push 30 frames with IDs 1-30 via 2 threads,
    /// verify output FrameId sequence is strictly 1,2,3,...,30</summary>
    private async Task RunScenario8()
    {
        if (_jpegData == null) return;
        _running = true;
        UpdateResult(8, "", "running");
        StateHasChanged();
        await Task.Yield();

        try
        {
            const int frameCount = 30;
            await using var pipeline = new WasmJpegDecodePipeline(_imageWidth, _imageHeight, workerCount: 2);

            var bitmaps = new SKBitmap[frameCount];
            for (int i = 0; i < frameCount; i++)
                bitmaps[i] = new SKBitmap(_imageWidth, _imageHeight, SKColorType.Bgra8888, SKAlphaType.Opaque);

            // Warmup
            await pipeline.PushAsync(new DecodeRequest(0, _jpegData, bitmaps[0]));
            await pipeline.ReadAsync();
            pipeline.Reset();

            // Push frames with IDs 1..30
            var receivedIds = new List<ulong>();

            var pushTask = Task.Run(async () =>
            {
                for (ulong i = 1; i <= frameCount; i++)
                    await pipeline.PushAsync(new DecodeRequest(i, _jpegData, bitmaps[i - 1]));
            });

            var readTask = Task.Run(async () =>
            {
                for (int i = 0; i < frameCount; i++)
                {
                    var result = await pipeline.ReadAsync();
                    lock (receivedIds) { receivedIds.Add(result.FrameId); }
                }
            });

            await Task.WhenAll(pushTask, readTask);

            // Verify strict ordering: 1, 2, 3, ..., 30
            bool inOrder = true;
            var outOfOrderAt = new List<string>();
            for (int i = 0; i < receivedIds.Count; i++)
            {
                ulong expected = (ulong)(i + 1);
                if (receivedIds[i] != expected)
                {
                    inOrder = false;
                    outOfOrderAt.Add($"pos {i}: got {receivedIds[i]} expected {expected}");
                }
            }

            var idSequence = string.Join(",", receivedIds.Take(10)) + (receivedIds.Count > 10 ? "..." : "");
            var pass = inOrder && receivedIds.Count == frameCount;

            if (pass)
            {
                UpdateResult(8, $"OK: {idSequence},{receivedIds.Count} frames in order", "PASS");
                Log($"[#8] Frame ordering: PASS — {receivedIds.Count} frames received in strict order 1..{frameCount}");
            }
            else
            {
                var issues = string.Join("; ", outOfOrderAt.Take(5));
                UpdateResult(8, $"OUT OF ORDER: {issues}", "FAIL");
                Log($"[#8] Frame ordering: FAIL — received {receivedIds.Count} frames, sequence: {idSequence}");
                Log($"[#8] Issues: {issues}");
            }

            foreach (var bmp in bitmaps) bmp.Dispose();
        }
        catch (Exception ex)
        {
            UpdateResult(8, ex.Message, "FAIL");
            Log($"[#8] Exception: {ex.Message}");
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.Black);

        if (_lastDecodedBitmap != null)
        {
            var destRect = new SKRect(0, 0, e.Info.Width, e.Info.Height);
            canvas.DrawBitmap(_lastDecodedBitmap, destRect);
        }
    }

    private void UpdateResult(int id, string result, string status)
    {
        var idx = _results.FindIndex(r => r.Id == id);
        if (idx >= 0)
        {
            var old = _results[idx];
            _results[idx] = old with { Result = result, Status = status };
        }
    }

    private void Log(string message)
    {
        _log += $"[{DateTime.Now:HH:mm:ss.fff}] {message}\n";
    }

    private record BenchmarkResult(int Id, string Name, string Threads, string Target, string Result, string Status)
    {
        public string StatusClass => Status switch
        {
            "PASS" => "pass",
            "FAIL" => "fail",
            "running" => "running",
            _ => ""
        };
    }
}
